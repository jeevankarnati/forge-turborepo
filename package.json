{
  "name": "forge-turborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "forge:deploy": "cd apps/main && forge deploy",
    "forge:install": "cd apps/main && forge install",
    "forge:register": "cd apps/main && forge register",
    "forge:upgrade": "cd apps/main && forge install --upgrade",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "generate:atlaskit-css": "bun run --filter @repo/tailwind-config generate:atlaskit-css",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "quality": "bun run lint && bun run format",
    "quality:fix": "bun run lint:fix && bun run format:fix"
  },
  "devDependencies": {
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "turbo": "^2.8.21",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
