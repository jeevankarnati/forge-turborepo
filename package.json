{
  "name": "forge-turborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "forge-deploy": "turbo run forge-deploy",
    "forge-install": "turbo run forge-install",
    "forge-install:upgrade": "turbo run forge-install:upgrade",
    "forge-register": "turbo run forge-register",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "quality": "bun run lint && bun run format",
    "quality:fix": "bun run lint:fix && bun run format:fix"
  },
  "devDependencies": {
    "eslint-plugin-check-file": "^3.3.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
